{
  "manifest_version": 3,
  "name": "Veris",
  "version": "1.0",
  "description": "Reliability ratings for news sources",
  "permissions": ["activeTab"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Veris"
  }
}